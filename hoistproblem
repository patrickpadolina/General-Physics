        .gresa-row.a { border-color: var(--accent-green); }

        .gresa-label {
            font-size: 0.95rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .gresa-row.g .gresa-label { color: var(--accent-blue); }
        .gresa-row.r .gresa-label { color: var(--accent-orange); }
        .gresa-row.e .gresa-label { color: #8b5cf6; }
        .gresa-row.s .gresa-label { color: var(--accent-red); }
        .gresa-row.a .gresa-label { color: var(--accent-green); }

        .math-block {
            background: #f1f5f9;
            padding: 4px 10px;
            border-radius: 4px;
            display: inline-block;
