        }

        /* Bottom Presenter Toolbar */
        .ppt-toolbar {
            background: white;
            border-top: 1px solid var(--border-color);
            padding: 8px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-shrink: 0;
        }

        .btn-group {
            display: flex;
            gap: 10px;
